#include<stdio.h>
void main()
{
    int n,i, evensum = 0 , oddsum = 0;
    printf("enter a number");
    scanf("%d", &n);
    for (i = 1; i <= n; i++)
    { 
       if(i % 2 == 0)
    {
        evensum = evensum + i ;
    }
    else
    {
        oddsum = oddsum + i;
     }
    }
    printf("\n sum of even number = %d", evensum);
    printf("\n sum of odd number = %d", oddsum);
    }
